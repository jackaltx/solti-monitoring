---
extends: default

# Ignore test output and generated files
ignore: |
  verify_output/
  .ansible/
  data/
  .tox/
  .venv/
  solti-venv/

rules:
  line-length: disable
  trailing-spaces: disable
  comments-indentation: disable
  comments:
    min-spaces-from-content: 1
  braces:
    max-spaces-inside: 1
  octal-values:
    forbid-implicit-octal: true
    forbid-explicit-octal: true
